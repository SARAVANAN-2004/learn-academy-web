<div class="home-wrapper">
    <SiteNavbar />

    <section id="home">
        <HeaderCarousel />
    </section>

    <section id="features">
        <ServiceFeatures />
    </section>

    <section id="about">
        <AboutSection />
    </section>

    <section id="categories">
        <CourseCategories @categories={{this.model.categories}} />
    </section>

    <section id="courses">
        <PopularCourses @courses={{this.model.courses}} />
    </section>

    <section id="instructors">
        <ExpertInstructors @instructors={{this.model.instructors}} />
    </section>

    <section id="testimonials">
        <StudentTestimonials @testimonials={{this.model.testimonials}} />
    </section>

    <section id="footer">
        <SiteFooter />
    </section>
</div>