{{page-title "Dashboard"}}

<div class="dashboard-page" style="padding: 2rem;">
    <main>
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
            <h2>Recommended for You</h2>

            <div class="dashboard-filters" style="display: flex; gap: 10px;">
                <button type="button" class="btn {{if (eq this.type 'all') 'btn-primary' 'btn-outline-primary'}}"
                    {{on "click" (fn this.setType 'all' )}}>All</button>
                <button type="button" class="btn {{if (eq this.type 'course') 'btn-primary' 'btn-outline-primary'}}"
                    {{on "click" (fn this.setType 'course' )}}>Courses</button>
                <button type="button" class="btn {{if (eq this.type 'test') 'btn-primary' 'btn-outline-primary'}}"
                    {{on "click" (fn this.setType 'test' )}}>Tests</button>
            </div>
        </div>

        <div class="dashboard-grid">
            {{#each this.filteredModel as |item|}}
            {{#if (or (eq item.type 'TEST') (eq item.type 'test'))}}
            <TestCard @test={{item}} @isEnrolled={{false}} />
            {{else}}
            <!-- Default to Course -->
            <CourseCard @course={{item}} @isEnrolled={{false}} />
            {{/if}}
            {{else}}
            <div class="empty-state"
                style="grid-column: 1 / -1; text-align: center; padding: 4rem; background: #f9fafa; border-radius: 8px;">
                <i class="fa-solid fa-folder-open" style="font-size: 3rem; color: #cbd5e1; margin-bottom: 1rem;"></i>
                <h3 style="color: #475569;">No items found</h3>
                <p style="color: #64748b;">Try changing your filter or check back later.</p>
            </div>
            {{/each}}
        </div>
    </main>
</div>