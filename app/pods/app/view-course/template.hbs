{{!-- Main Content --}}
<div class="container-fluid mt-4 view-course-page">
    <div class="row">
        {{!-- Video Section --}}
        <div class="col-md-8">
            <div class="course-header">
                <h2>{{this.model.courseDetails.title}}</h2>

                <div class="course-meta">
                    <span>{{this.model.courseDetails.instructor}}</span>
                    <span>⭐ {{this.model.courseDetails.rating}}</span>
                    <span class="price">₹{{this.model.courseDetails.price}}</span>
                </div>

                <p class="course-desc">
                    {{this.model.courseDetails.description}}
                </p>
            </div>

            <div class="video-container mt-3">
                <iframe id="course-video" width="100%" height="400px" src={{this.embedVideoUrl}} frameborder="0"
                    allowfullscreen>
                </iframe>
            </div>

            <div class="mt-3">
                <h5 id="current-lesson-title">{{this.currentLesson.title}}</h5>
                <div id="lesson-resources">
                    <strong>Resources:</strong> {{if this.currentLesson.resources this.currentLesson.resources 'None'}}
                </div>
            </div>
        </div>

        {{!-- Sidebar --}}
        <div class="col-md-4">
            <h4>Course Lessons</h4>
            <div class="accordion" id="courseAccordion">
                {{#each this.model.content.sections as |section i|}}
                <div class="accordion-item section">
                    <h2 class="accordion-header">
                        <button class="accordion-button {{if (not-eq i 0) 'collapsed' ''}}" type="button"
                            data-bs-toggle="collapse" data-bs-target="#section{{i}}">
                            {{section.title}}
                        </button>
                    </h2>
                    <div id="section{{i}}" class="accordion-collapse collapse {{if (eq i 0) 'show' ''}}">
                        <div class="accordion-body">
                            <ul class="list-group">
                                {{#each section.lessons as |lesson|}}
                                <li class="list-group-item lesson lesson-item {{if (eq lesson this.currentLesson) 'active'}}"
                                    role="button" {{on "click" (action this.selectLesson lesson)}}>
                                    <input type="checkbox" checked={{get this.progressMap lesson.lesson_id}}
                                        {{on "change" (action this.toggleLesson lesson)}}> {{lesson.title}}
                                </li>
                                {{/each}}
                            </ul>
                        </div>
                    </div>
                </div>
                {{/each}}
            </div>
        </div>
    </div>

    {{!-- Tabs --}}
    <div class="tabs-container mt-4">
        <ul class="nav nav-tabs" id="courseTabs">
            <li class="nav-item">
                <a class="nav-link active" data-bs-toggle="tab" href="#overview">Overview</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#qna">Q&A</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#resources">Resources</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#reviews">Reviews</a>
            </li>
        </ul>

        <div class="tab-content mt-3">
            <div class="tab-pane fade show active" id="overview">
                <h5>Course Summary</h5>
                <p>{{this.model.content.summary}}</p>
                <p><strong>Requirements:</strong> {{this.model.courseDetails.requirements}}</p>
                <p><strong>Target Audience:</strong> {{this.model.courseDetails.targetAudience}}</p>
                <p><strong>Instructor:</strong> {{this.model.courseDetails.instructor}}</p>
                <p><strong>Time Commitment:</strong> {{this.model.courseDetails.timeCommitment}} hours/week</p>
                <p><strong>Category:</strong> {{this.model.courseDetails.category}}</p>
            </div>

            <div class="tab-pane fade" id="qna">
                <p>Have questions? Post them here, and our instructors will respond.</p>
                <textarea class="form-control" placeholder="Ask a question..."></textarea>
                <button type="button" class="btn btn-primary mt-2">Submit</button>
            </div>

            <div class="tab-pane fade" id="resources">
                <p><i>Select a lesson to view its resources.</i></p>
            </div>

            <div class="tab-pane fade" id="reviews">
                <h5>Student Reviews</h5>
                <textarea class="form-control" placeholder="Write a review..."></textarea>
                <button type="button" class="btn btn-primary mt-2">Submit</button>
            </div>
        </div>
    </div>
</div>