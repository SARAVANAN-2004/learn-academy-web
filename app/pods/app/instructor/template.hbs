<div class="instructor-page">
    <div class="instructor-layout">
        <aside class="sidebar">
            <h2>Instructor</h2>
            <ul>
                <li>
                    <LinkTo @route="app.instructor.dashboard">🏠 Dashboard</LinkTo>
                </li>
                <li>
                    <LinkTo @route="app.instructor.enrollment-steps" @model="new">➕ Create Course</LinkTo>
                </li>
                <li>
                    <LinkTo @route="app.instructor.create-test">➕ Create Test</LinkTo>
                </li>
                <li>
                    <LinkTo @route="app.instructor.courses">📚 Courses</LinkTo>
                </li>
                <li>
                    <LinkTo @route="app.instructor.tests">📋 Tests</LinkTo>
                </li>
                <li>
                    <LinkTo @route="app.instructor.reports">📊 Reports</LinkTo>
                </li>
            </ul>
        </aside>

        <main class="main-content">
            {{outlet}}
        </main>
    </div>
</div>