<div class="dashboard-layout">
    <main class="dashboard-main">
        <header class="main-header modern">
            <div class="header-text">
                <h1>Welcome back <span class="wave">👋</span></h1>
                <p class="overview-text">Your teaching performance overview</p>
            </div>
            <div class="header-actions">
                <button class="cta-btn primary" {{on "click" this.goToEnrollment}}>
                    + Create Course
                </button>
            </div>
        </header>

        {{#if this.model.totalCourses}}

        {{!-- Stats Grid --}}
        <section class="stats-grid modern">
            <div class="stat-card">
                <div class="stat-meta">
                    <span class="stat-label">Total Courses</span>
                    <span class="stat-icon pink">📚</span>
                </div>
                <h2>{{this.model.totalCourses}}</h2>
            </div>
            <div class="stat-card">
                <div class="stat-meta">
                    <span class="stat-label">Total Students</span>
                    <span class="stat-icon blue">👨‍🎓</span>
                </div>
                <h2>{{this.model.totalStudents}}</h2>
            </div>
            <div class="stat-card">
                <div class="stat-meta">
                    <span class="stat-label">Total Lessons</span>
                    <span class="stat-icon purple">📖</span>
                </div>
                <h2>{{this.model.totalLessons}}</h2>
            </div>
            <div class="stat-card gradient-card">
                <div class="stat-meta">
                    <span class="stat-label">Avg Completion</span>
                    <span class="stat-icon white">📊</span>
                </div>
                <h2>{{this.roundedAvgCompletion}}%</h2>
            </div>
            <!-- Added Test Analytics -->
            <div class="stat-card">
                <div class="stat-meta">
                    <span class="stat-label">Total Test Enrollments</span>
                    <span class="stat-icon" style="background: rgba(111,66,193,0.1); color: #6f42c1;">📝</span>
                </div>
                <h2>{{if this.model.totalTestEnrollments this.model.totalTestEnrollments 0}}</h2>
            </div>
            <div class="stat-card">
                <div class="stat-meta">
                    <span class="stat-label">Avg Test Completion</span>
                    <span class="stat-icon" style="background: rgba(111,66,193,0.1); color: #6f42c1;">🎯</span>
                </div>
                <h2>{{if this.model.avgTestCompletion this.model.avgTestCompletion "0%"}}</h2>
            </div>
        </section>

        {{!-- Insights Panel --}}
        <section class="insights-panel modern">
            <div class="insight-card light-blue">
                <div class="insight-icon">🏆</div>
                <div class="insight-content">
                    <span class="insight-label">Top Course</span>
                    <h4>{{this.model.topCourse.title}}</h4>
                    <p>{{this.model.topCourse.students}} students</p>
                </div>
            </div>
            <div class="insight-card light-green">
                <div class="insight-icon">📈</div>
                <div class="insight-content">
                    <span class="insight-label">Overall Growth</span>
                    <h4>+{{this.model.growthRate}}%</h4>
                </div>
            </div>
            <div class="insight-card light-purple">
                <div class="insight-icon">⏰</div>
                <div class="insight-content">
                    <span class="insight-label">Peak Activity Time</span>
                    <h4>{{this.model.peakActivityTime}}</h4>
                </div>
            </div>
        </section>

        {{!-- Charts --}}
        <section class="charts-wrap modern" {{did-insert this.setupCharts}}>
            <div class="charts-row split">
                <div class="chart-card span-2">
                    <div class="chart-header">
                        <h3>Student Growth</h3>
                        <span class="chart-badge line">Line</span>
                    </div>
                    <div class="chart-container">
                        <canvas id="growthChart"></canvas>
                    </div>
                </div>
                <div class="chart-card">
                    <div class="chart-header">
                        <h3>Engagement Trend</h3>
                        <span class="chart-badge area">Area</span>
                    </div>
                    <div class="chart-container">
                        <canvas id="engagementChart"></canvas>
                    </div>
                </div>
            </div>

            <div class="charts-row three-col">
                <div class="chart-card">
                    <div class="chart-header">
                        <h3>Students per Course</h3>
                        <span class="chart-badge bar">Bar</span>
                    </div>
                    <div class="chart-container">
                        <canvas id="studentsChart"></canvas>
                    </div>
                </div>
                <div class="chart-card">
                    <div class="chart-header">
                        <h3>Completed Lessons</h3>
                        <span class="chart-badge bar">Bar</span>
                    </div>
                    <div class="chart-container">
                        <canvas id="completedChart"></canvas>
                    </div>
                </div>
                <div class="chart-card">
                    <div class="chart-header">
                        <h3>Completion Overview</h3>
                        <span class="chart-badge doughnut">Doughnut</span>
                    </div>
                    <div class="chart-container doughnut-wrap">
                        <canvas id="completionChart"></canvas>
                        <div class="doughnut-center">
                            <span class="value">{{this.roundedAvgCompletion}}%</span>
                            <span class="label">Avg</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {{!-- Bottom Row --}}
        <section class="bottom-row">
            <div class="leaderboard-card">
                <h3>Top Performing Courses</h3>
                <ul class="leaderboard-list">
                    {{#each this.model.topCourses as |course index|}}
                    <li>
                        <div class="rank">★</div>
                        <div class="course-info">
                            <h4>{{course.title}}</h4>
                        </div>
                        <div class="course-metrics">
                            <strong>{{course.students}}</strong>
                            <span>students</span>
                        </div>
                    </li>
                    {{/each}}
                </ul>
            </div>

            <div class="table-card">
                <h3>Course Analytics</h3>
                <div class="table-responsive">
                    <table class="modern-table">
                        <thead>
                            <tr>
                                <th>Course Name</th>
                                <th>Students</th>
                                <th>Lessons</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each this.model.courseAnalytics as |course|}}
                            <tr>
                                <td>{{course.title}}</td>
                                <td>{{course.students}}</td>
                                <td>{{course.completedLessons}}</td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        {{else}}
        {{!-- Empty State --}}
        <div class="empty-state modern-empty">
            <div class="empty-illustration">
                <img src="https://placehold.co/400x300/f8fafc/6c63ff?text=No+Data" alt="No analytics yet">
            </div>
            <h2>No analytics yet</h2>
            <p>You haven't published any courses yet. Once you do, your analytics will appear here.</p>
            <button class="cta-btn primary large" {{on "click" this.goToEnrollment}}>
                + Create Your First Course
            </button>
        </div>
        {{/if}}
    </main>
</div>