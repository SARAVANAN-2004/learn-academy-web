{{page-title "My Learning"}}

<header>
    <div class="logo">IQMath</div>
    <nav>
        <ul class="nav-links">
            <li><a href="/dashboard">Explore</a></li>
            <li><a href="/AddCourseContent/MainCoursePage.html">Teach on IQMath</a></li>
            <li><a href="/mylearning">My Learning</a></li>
        </ul>
    </nav>
    <input type="text" class="search-bar" placeholder="Search courses..." />
    <div class="icons">
        <span class="icon">🛒</span>
        <span class="icon">🔔</span>
        <a href="/Profile/index.html"><span class="icon">👤</span></a>
        <button type="button" class="logout-btn"
            style="background: none; border: none; font-size: 1.2rem; cursor: pointer; margin-left: 10px;" {{on "click"
            this.logout}} title="Logout">🚪</button>
    </div>
</header>

<main>
    <h2>My Courses</h2>

    {{#if this.model.length}}
    <div class="dashboard-grid">
        {{#each this.model as |course|}}
        <CourseCard @course={{course}} @isEnrolled={{true}} />
        {{/each}}
    </div>
    {{else}}
    <p style="text-align: center; font-size: 1.2rem; margin-top: 50px; color: #555;">You have not enrolled in any
        courses yet.</p>
    {{/if}}
</main>