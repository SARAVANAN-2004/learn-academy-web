<!-- Team Start -->
<div class="container-xxl py-5">
    <div class="container">
        <div class="text-center wow fadeInUp" data-wow-delay="0.1s">
            <h6 class="section-title bg-white text-center text-primary px-3">Instructors</h6>
            <h1 class="mb-5">Expert Instructors</h1>
        </div>
        <div class="row g-4">
            {{#each @instructors as |instructor index|}}
            <div class="col-lg-3 col-md-6 wow fadeInUp"
                data-wow-delay="{{if (eq index 0) '0.1s' (if (eq index 1) '0.3s' (if (eq index 2) '0.5s' '0.7s'))}}">
                <div class="team-item bg-light">
                    <div class="overflow-hidden">
                        <img class="img-fluid" src="{{instructor.image}}" alt="">
                    </div>
                    <div class="position-relative d-flex justify-content-center instructor-social">
                        <div class="bg-light d-flex justify-content-center pt-2 px-1">
                            <a class="btn btn-sm-square btn-primary mx-1" href="{{instructor.social.facebook}}"><i
                                    class="fab fa-facebook-f"></i></a>
                            <a class="btn btn-sm-square btn-primary mx-1" href="{{instructor.social.twitter}}"><i
                                    class="fab fa-twitter"></i></a>
                            <a class="btn btn-sm-square btn-primary mx-1" href="{{instructor.social.instagram}}"><i
                                    class="fab fa-instagram"></i></a>
                        </div>
                    </div>
                    <div class="text-center p-4">
                        <h5 class="mb-0">{{instructor.name}}</h5>
                        <small>{{instructor.designation}}</small>
                    </div>
                </div>
            </div>
            {{/each}}
        </div>
    </div>
</div>
<!-- Team End -->