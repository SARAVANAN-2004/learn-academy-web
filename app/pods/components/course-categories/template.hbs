<!-- Categories Start -->
<div class="container-xxl py-5 category">
    <div class="container">
        <div class="text-center wow fadeInUp" data-wow-delay="0.1s">
            <h6 class="section-title bg-white text-center text-primary px-3">Categories</h6>
            <h1 class="mb-5">Courses Categories</h1>
        </div>
        <div class="row g-3">
            <div class="col-lg-7 col-md-6">
                <div class="row g-3">
                    {{#each @categories as |category index|}}
                    {{#if (lt index 3)}}
                    <div class="{{if (eq index 0) 'col-lg-12 col-md-12' 'col-lg-6 col-md-12'}} wow zoomIn"
                        data-wow-delay="{{if (eq index 0) '0.1s' (if (eq index 1) '0.3s' '0.5s')}}">
                        <a class="position-relative d-block overflow-hidden" href="">
                            <img class="img-fluid" src="{{category.image}}" alt="">
                            <div
                                class="bg-white text-center position-absolute bottom-0 end-0 py-2 px-3 course-category-count-box">
                                <h5 class="m-0">{{category.name}}</h5>
                                <small class="text-primary">{{category.count}} Courses</small>
                            </div>
                        </a>
                    </div>
                    {{/if}}
                    {{/each}}
                </div>
            </div>
            {{#if (gt @categories.length 3)}}
            {{#each @categories as |category index|}}
                {{#if (eq index 3)}}
                <div class="col-lg-5 col-md-6 wow zoomIn course-category-card" data-wow-delay="0.7s">
                    <a class="position-relative d-block h-100 overflow-hidden" href="#">
                    <img
                        class="img-fluid position-absolute w-100 h-100 course-category-img"
                        src={{category.image}}
                        alt=""
                    />
                    <div class="bg-white text-center position-absolute bottom-0 end-0 py-2 px-3 course-category-count-box">
                        <h5 class="m-0">{{category.name}}</h5>
                        <small class="text-primary">{{category.count}} Courses</small>
                    </div>
                    </a>
                </div>
                {{/if}}
            {{/each}}
            {{/if}}
        </div>
    </div>
</div>
<!-- Categories Start -->