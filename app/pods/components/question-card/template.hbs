<div class='question-card'>
  <div class='question-header'>
    <span class='question-number'>Question {{this.displayIndex}}</span>
    <button
      type='button'
      class='btn btn-icon btn-remove'
      {{on 'click' @onRemoveQuestion}}
    >
      &times;
    </button>
  </div>

  <div class='form-group row'>
    <div class='col-8'>
      <label>Question Text</label>
      <input
        type='text'
        id='question-text-{{this.question.id}}'
        name='question-text-{{this.question.id}}'
        class='form-control'
        value={{this.question.text}}
        placeholder='Enter your question here...'
        {{on 'input' (fn this.onUpdateField 'text')}}
      />
    </div>
    <div class='col-4'>
      <label>Question Type</label>
      <select
        id='question-type-{{this.question.id}}'
        name='question-type-{{this.question.id}}'
        class='form-control form-select'
        {{on 'change' (fn this.onUpdateField 'type')}}
      >
        {{#each this.questionTypes key='@index' as |type|}}
          <option value={{type}} selected={{eq this.question.type type}}>
            {{type}}
          </option>
        {{/each}}
      </select>
    </div>
  </div>

  <div class='form-group row'>
    <div class='col-4'>
      <label>Marks</label>
      <input
        type='number'
        id='question-marks-{{this.question.id}}'
        name='question-marks-{{this.question.id}}'
        class='form-control'
        min='1'
        value={{this.question.marks}}
        {{on 'input' (fn this.onUpdateField 'marks')}}
      />
    </div>
    <div class='col-8'>
      <label>Explanation (Optional)</label>
      <input
        type='text'
        id='question-explanation-{{this.question.id}}'
        name='question-explanation-{{this.question.id}}'
        class='form-control'
        value={{this.question.explanation}}
        placeholder='Explanation for the correct answer...'
        {{on 'input' (fn this.onUpdateField 'explanation')}}
      />
    </div>
  </div>

  {{! Dynamic Options based on type }}
  <div class='question-options'>
    {{#if (eq this.question.type 'MCQ')}}
      <label>Options</label>
      {{#each this.question.options key='id' as |opt optIndex|}}
        <div class='option-row'>
          <input
            type='radio'
            id='mcq-correct-{{this.question.id}}-{{opt.id}}'
            name='mcq-correct-{{this.question.id}}'
            checked={{opt.isCorrect}}
            {{on 'change' (fn this.onUpdateOption optIndex 'isCorrect')}}
          />
          <input
            type='text'
            id='mcq-text-{{this.question.id}}-{{opt.id}}'
            name='mcq-text-{{this.question.id}}-{{opt.id}}'
            class='form-control'
            value={{opt.text}}
            placeholder='Option text'
            {{on 'input' (fn this.onUpdateOption optIndex 'text')}}
          />
          <button
            type='button'
            class='btn btn-icon text-danger option-remove-button'
            {{on 'click' (fn @onRemoveOption this.question.id optIndex)}}
          >&times;</button>
        </div>
      {{/each}}
      <button
        type='button'
        class='btn btn-secondary btn-sm mt-2'
        {{on 'click' this.onAddOption}}
      >
        + Add Option
      </button>

    {{else if (eq this.question.type 'TRUE_FALSE')}}
      <label>Correct Answer</label>
      <select
        id='tf-answer-{{this.question.id}}'
        name='tf-answer-{{this.question.id}}'
        class='form-control form-select'
        {{on 'change' (fn this.onUpdateField 'correctAnswer')}}
      >
        <option
          value='true'
          selected={{eq this.question.correctAnswer 'true'}}
        >True</option>
        <option
          value='false'
          selected={{eq this.question.correctAnswer 'false'}}
        >False</option>
      </select>

    {{else if (eq this.question.type 'FILL')}}
      <label>Correct Answer Text</label>
      <input
        type='text'
        id='fill-answer-{{this.question.id}}'
        name='fill-answer-{{this.question.id}}'
        class='form-control'
        value={{this.question.correctAnswer}}
        placeholder='Enter the correct answer...'
        {{on 'input' (fn this.onUpdateField 'correctAnswer')}}
      />
    {{/if}}
  </div>
</div>